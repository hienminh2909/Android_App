<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/Vitri"
    android:background="@drawable/img_15"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".vitri">

    <TextView
        android:id="@+id/txt_vitri"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Vitri"
        android:textSize="16sp"
        android:textColor="#000000"
        app:layout_constraintLeft_toLeftOf="@id/Vitri"
        app:layout_constraintTop_toTopOf="@id/Vitri"
        android:layout_marginTop="10dp"/>

    <ImageView
        android:id="@+id/img_vt"
        android:layout_width="258dp"
        android:layout_height="353dp"
        android:layout_marginTop="10dp"
        app:layout_constraintLeft_toLeftOf="@id/Vitri"
        app:layout_constraintTop_toBottomOf="@id/txt_vitri"
        app:srcCompat="@drawable/img_3" />


</androidx.constraintlayout.widget.ConstraintLayout>