<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dacsan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_12"
    android:fitsSystemWindows="true"
    tools:context=".dacsan">

    <TextView
        android:id="@+id/txt_ds1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:background="#00DDFF"
        android:text="1. Mì Quảng"
        android:textSize="20sp"
        app:layout_constraintLeft_toLeftOf="@id/dacsan"
        app:layout_constraintTop_toTopOf="@id/dacsan" />

    <ImageView
        android:id="@+id/img_ds1"
        android:layout_width="230dp"
        android:layout_height="130dp"
        app:layout_constraintLeft_toLeftOf="@id/dacsan"
        app:layout_constraintRight_toRightOf="@id/dacsan"
        app:layout_constraintTop_toBottomOf="@id/txt_ds1"
        app:srcCompat="@drawable/img_1" />

    <TextView
        android:id="@+id/nd_ds1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/MiQuang"
        android:textSize="11sp"
        app:layout_constraintLeft_toLeftOf="@id/dacsan"
        app:layout_constraintTop_toBottomOf="@id/img_ds1" />

    <TextView
        android:id="@+id/txt_ds2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="#00DDFF"
        android:text="2.  Cơm gà Tam Kỳ"
        android:textSize="20sp"
        app:layout_constraintLeft_toLeftOf="@id/dacsan"
        app:layout_constraintTop_toBottomOf="@id/nd_ds1" />

    <ImageView
        android:id="@+id/img_ds2"
        android:layout_width="230dp"
        android:layout_height="130dp"
        app:layout_constraintLeft_toLeftOf="@id/dacsan"
        app:layout_constraintRight_toRightOf="@id/dacsan"
        app:layout_constraintTop_toBottomOf="@id/txt_ds2"
        app:srcCompat="@drawable/img_2" />

    <TextView
        android:id="@+id/nd_ds2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ComGa"
        android:textSize="11sp"
        app:layout_constraintLeft_toLeftOf="@id/dacsan"
        app:layout_constraintTop_toBottomOf="@id/img_ds2" />


</androidx.constraintlayout.widget.ConstraintLayout>