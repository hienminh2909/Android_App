<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/danhgia"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5F5"
    tools:context=".danhgia">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cảm ơn bạn đã đánh giá nhé !"
        android:textSize="27sp"
        android:textColor="#FF4611"
        app:layout_constraintBottom_toBottomOf="@id/danhgia"
        app:layout_constraintTop_toTopOf="@id/danhgia"
        app:layout_constraintRight_toRightOf="@id/danhgia"
        app:layout_constraintLeft_toLeftOf="@id/danhgia"
        android:layout_marginTop="-100dp"
        />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="95dp"
        android:layout_height="72dp"
        android:layout_marginTop="50dp"
        app:layout_constraintBottom_toBottomOf="@id/danhgia"
        app:layout_constraintLeft_toLeftOf="@id/danhgia"
        app:layout_constraintRight_toRightOf="@id/danhgia"
        app:layout_constraintTop_toTopOf="@id/danhgia"
        app:srcCompat="@drawable/danhgia" />


</androidx.constraintlayout.widget.ConstraintLayout>