<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ABBFCC"
    tools:context=".edit_bmi">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardCornerRadius="40dp"
        android:layout_marginRight="5dp"
        android:layout_marginLeft="5dp"
        android:clickable="true"
        android:layout_marginBottom="340dp"
        app:cardElevation="20dp"
        android:foreground="?attr/selectableItemBackground"
        android:id="@+id/card_height"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/height">
        <TextView
            android:id="@+id/txt_height"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="@id/height"
            app:layout_constraintTop_toTopOf="@id/height"
            app:layout_constraintBottom_toBottomOf="@id/height"
            android:text="Chiều cao:"
            android:textSize="20dp"
            android:layout_marginLeft="10dp"
        />
        <ImageView
            android:id="@+id/img_height"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:srcCompat="@drawable/img_2"
            app:layout_constraintTop_toTopOf="@id/height"
            app:layout_constraintBottom_toBottomOf="@id/height"
            app:layout_constraintLeft_toRightOf="@id/txt_height"
            />
            <EditText
                android:id="@+id/ed_height"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Nhập chiều cao (m)"
                app:layout_constraintTop_toTopOf="@id/height"
                app:layout_constraintBottom_toBottomOf="@id/height"
                app:layout_constraintLeft_toRightOf="@id/img_height"
                android:inputType="numberDecimal"
                android:padding="10dp"
                />
      </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardCornerRadius="40dp"
        android:layout_marginRight="5dp"
        android:layout_marginLeft="5dp"
        android:clickable="true"
        android:layout_marginBottom="80dp"
        app:cardElevation="20dp"
        android:foreground="?attr/selectableItemBackground"
        android:id="@+id/card_weight"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/weight">
            <TextView
                android:id="@+id/txt_weight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@id/weight"
                app:layout_constraintTop_toTopOf="@id/weight"
                app:layout_constraintBottom_toBottomOf="@id/weight"
                android:text="Cân nặng:"
                android:textSize="20dp"
                android:layout_marginLeft="10dp"
                />
            <ImageView
                android:id="@+id/img_weight"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:srcCompat="@drawable/img_2"
                app:layout_constraintTop_toTopOf="@id/weight"
                app:layout_constraintBottom_toBottomOf="@id/weight"
                app:layout_constraintLeft_toRightOf="@id/txt_weight"
                />
            <EditText
                android:id="@+id/ed_weight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Nhập cân nặng (kg)"
                app:layout_constraintTop_toTopOf="@id/weight"
                app:layout_constraintBottom_toBottomOf="@id/weight"
                app:layout_constraintLeft_toRightOf="@id/img_weight"
                android:inputType="numberDecimal"
                android:padding="10dp"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="150dp"
        android:layout_height="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardCornerRadius="40dp"
        android:layout_marginRight="5dp"
        android:layout_marginLeft="5dp"
        android:clickable="true"
        android:layout_marginTop="300dp"
        app:cardElevation="20dp"
        android:foreground="?attr/selectableItemBackground"
        android:id="@+id/card_btncal"
        >
        <ImageButton
            android:id="@+id/img_btncal"
            android:layout_width="185dp"
            android:layout_height="140dp"
            app:srcCompat="@drawable/img_6"

            />

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>