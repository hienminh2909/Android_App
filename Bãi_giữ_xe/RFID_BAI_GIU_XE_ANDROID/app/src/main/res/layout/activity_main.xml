<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#C5FFF7"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/txt_tieude"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUẢN LÝ BÃI GIỮ XE"
        android:layout_marginTop="40dp"
        android:textSize="30dp"
        android:textStyle="bold"
        android:textColor="#FF0909"
        android:background="#05DEFF"
        app:layout_constraintEnd_toEndOf="@id/main"
        app:layout_constraintStart_toStartOf="@id/main"
        app:layout_constraintTop_toTopOf="@id/main" />

    <Button
        android:id="@+id/btn_bienso"
        android:layout_width="120dp"
        android:layout_height="70dp"
        android:text="Nhập dữ liệu"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/txt_tieude"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="5dp"
        app:layout_constraintLeft_toLeftOf="@id/main"
        android:backgroundTint="#00A3FF"
        android:textColor="@color/black"/>
    <Button
        android:id="@+id/btn_danhsach"
        android:layout_width="120dp"
        android:layout_height="70dp"
        android:text="Danh sách xe"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/txt_tieude"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="5dp"
        app:layout_constraintLeft_toRightOf="@id/btn_bienso"
        android:backgroundTint="#00A3FF"
        android:textColor="@color/black"/>
    <Button
        android:id="@+id/btn_lichsu"
        android:layout_width="100dp"
        android:layout_height="70dp"
        android:text="Lịch sử"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/txt_tieude"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="5dp"
        app:layout_constraintLeft_toRightOf="@id/btn_danhsach"
        android:backgroundTint="#00A3FF"
        android:textColor="@color/black"/>

    <TextView
        android:id="@+id/txt_ID"
        android:layout_width="110dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn_danhsach"
        android:text="    ID :"
        android:textSize="25dp"
        android:background="#00FFDC"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="50dp"/>
    <TextView
        android:id="@+id/txt_numberID"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/btn_danhsach"
        android:text=""
        android:textSize="25dp"
        app:layout_constraintLeft_toLeftOf="@id/txt_ID"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="50dp"/>

    <TextView
        android:id="@+id/txt_bienso"
        android:layout_width="110dp"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/txt_ID"
        android:text="Biển số:"
        android:textSize="25dp"
        android:background="#00FFDC"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="50dp"/>
    <EditText
        android:id="@+id/ed_bienso"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/txt_numberID"
        android:text="abkhjdjlka"
        android:textSize="25dp"
        app:layout_constraintLeft_toLeftOf="@id/txt_ID"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="40dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/text_bienso"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/txt_numberID"
        android:text="abkhjdjlka"
        android:textSize="25dp"
        app:layout_constraintLeft_toLeftOf="@id/txt_ID"
        android:layout_marginLeft="120dp"
        android:layout_marginTop="40dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btn_xevao"
        android:layout_width="120dp"
        android:layout_height="70dp"
        android:text="Xe vào "
        android:textSize="23dp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/ed_bienso"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="100dp"
        android:layout_marginRight="10dp"
        android:backgroundTint="#00FF69"
        android:visibility="gone"
        />
    <Button
        android:id="@+id/btn_xera"
        android:layout_width="120dp"
        android:layout_height="70dp"
        android:text="Xe ra "
        android:textSize="23dp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/ed_bienso"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="100dp"
        android:layout_marginRight="10dp"
        android:backgroundTint="#FB3939"
        android:visibility="gone"
        />
    <Button
        android:id="@+id/btn_tuchoi"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:text="Từ chối "
        android:textSize="23dp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/ed_bienso"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginTop="100dp"
        android:layout_marginRight="10dp"
        android:backgroundTint="#FB3939"
        android:visibility="invisible"
        />
    <TextView
        android:id="@+id/txt_soluong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/btn_tuchoi"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="10dp"
        android:text="Số xe trong bãi: "
        android:textSize="25dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>