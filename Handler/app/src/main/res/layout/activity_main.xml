<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/img_back"
        android:layout_width="400dp"
        android:layout_height="200dp"
        app:srcCompat="@drawable/img"
        app:layout_constraintLeft_toLeftOf="@id/main"
        app:layout_constraintRight_toRightOf="@id/main"
        android:layout_marginTop="-15dp"
        app:layout_constraintTop_toTopOf="@id/main" />

    <ImageView
        android:id="@+id/img_lq"
        android:layout_width="100dp"
        android:layout_height="93dp"
        app:srcCompat="@drawable/img_1"
        android:layout_marginTop="10dp"
        app:layout_constraintLeft_toLeftOf="@id/main"
        app:layout_constraintTop_toBottomOf="@id/img_back" />

    <TextView
        android:id="@+id/txt_lq"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:text="Garena Liên Quân Mobile"
        android:textSize="28dp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintLeft_toRightOf="@id/img_lq"
        app:layout_constraintTop_toBottomOf="@id/img_back"
         />

    <TextView
        android:id="@+id/txt_phantram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chưa cài đặt"
        android:textSize="20dp"
        android:layout_marginTop="5dp"
        app:layout_constraintLeft_toLeftOf="@id/main"
        app:layout_constraintRight_toRightOf="@id/main"
        app:layout_constraintTop_toBottomOf="@id/img_lq"
        />

    <ProgressBar
        android:id="@+id/thanhtai"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="350dp"
        android:layout_height="25dp"
        android:layout_marginTop="5dp"
        app:layout_constraintLeft_toLeftOf="@id/main"
        app:layout_constraintRight_toRightOf="@id/main"
        app:layout_constraintTop_toBottomOf="@id/txt_phantram" />

    <Button
        android:id="@+id/btn_caidat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cài đặt"
        android:textSize="20dp"
        android:padding="10dp"
        android:textColor="@color/black"
        android:backgroundTint="#90E1FA"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="@id/main"
        app:layout_constraintRight_toRightOf="@id/main"
        app:layout_constraintTop_toBottomOf="@id/thanhtai"/>

    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="@id/main"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/txt_xephang" />

    <TextView
        android:id="@+id/txt_xephang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xếp hạng ứng dụng này"
        android:textSize="22dp"
        android:layout_marginTop="20dp"
        app:layout_constraintLeft_toLeftOf="@id/main"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toBottomOf="@id/btn_caidat" />

    <Button
        android:id="@+id/btn_danhgia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đánh giá"
        android:textSize="22dp"
        android:backgroundTint="#FF0000"
        app:layout_constraintLeft_toLeftOf="@id/main"
        android:layout_marginLeft="10dp"
        app:layout_constraintTop_toBottomOf="@id/ratingBar" />

</androidx.constraintlayout.widget.ConstraintLayout>